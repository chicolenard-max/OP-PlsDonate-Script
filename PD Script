-- Chat-System
lokale Funktion say(msg)
    Wenn msg nicht oder msg gleich "" ist, dann gib das Ende zurück
    pcall(function()
        Wenn TextChatService.ChatVersion == Enum.ChatVersion.TextChatService dann
            local ch = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if ch then ch:SendAsync(msg) end
        anders
            game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg, "All")
        Ende
    Ende)
Ende

-- Überprüfen Sie die Meldung "Belegter Stand!"
lokale Funktion checkForClaimedMessage()
    local playerGui = player:WaitForChild("PlayerGui")
    
    for _, gui in pairs(playerGui:GetDescendants()) do
        if gui:IsA("TextLabel") or gui:IsA("TextButton") then
            local text = gui.Text:lower()
            Wenn text:find("claimed") und text:find("booth") dann
                print("✅ Meldung 'Stand belegt!' erkannt!")
                return true
            Ende
        Ende
    Ende
    return false
Ende

