    i.Text = tostring(settings[key] or "")
    i.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    i.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", i)
    i.FocusLost:Connect(function()
        Wenn isN dann settings[key] = tonumber(i.Text) oder settings[key] sonst settings[key] = i.Text ~= "" und i.Text oder settings[key] Ende
        speichern()
    Ende)
    return i
Ende

